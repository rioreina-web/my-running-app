# Supabase config.toml env() interpolation values.
#
# Local dev: copy to supabase/.env (gitignored) and fill in dev values.
# Production: set these in Supabase dashboard → Project Settings → Configuration.
#
# Read by `supabase start` and `supabase db push` when config.toml uses env(VAR).

# Public site URL (where users land after auth callbacks)
SITE_URL=http://127.0.0.1:3000

# Additional URL allowed for auth redirects (e.g., production domain in dev config)
ADDITIONAL_REDIRECT_URL=http://127.0.0.1:3000

# SMTP — required when [auth.email.smtp] is enabled
SENDGRID_API_KEY=
SMTP_ADMIN_EMAIL=admin@postrundrip.com
SMTP_SENDER_NAME=Post Run Drip
