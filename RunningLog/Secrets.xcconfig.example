// Secrets.xcconfig.example
// Copy this to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored — never commit it.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
VITAL_API_KEY = your-vital-api-key-here
VITAL_USER_ID = your-vital-user-id-here
SENTRY_DSN = https:/$()/your-key@o12345.ingest.us.sentry.io/67890
