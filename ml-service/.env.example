# ML service environment variables.
# Local: copy to .env (gitignored) and fill in.
# Production: set in Railway dashboard.

# === Required ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# === Optional ===
PORT=8000
# Comma-separated list of origins allowed to call this service.
# Production: set to web app domain only (e.g., https://app.postrundrip.com).
ALLOWED_ORIGINS=http://localhost:3000

# === Sentry (optional, prod only) ===
SENTRY_DSN=
ENV=production
